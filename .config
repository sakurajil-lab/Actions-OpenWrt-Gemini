# 硬件平台设置
CONFIG_TARGET_ipq60xx=y
CONFIG_TARGET_ipq60xx_generic=y
CONFIG_TARGET_ipq60xx_generic_DEVICE_redmi_ax5=y

# 基础组件精简 (去掉不需要的无线驱动)
# CONFIG_PACKAGE_kmod-ath11k is not set
# CONFIG_PACKAGE_ath11k-firmware-ax5 is not set
# CONFIG_PACKAGE_wpad-basic-wolfssl is not set

# 核心功能：AdGuard Home
CONFIG_PACKAGE_luci-app-adguardhome=y

# 网络加速 (由于是旁路由/DNS服务器，保留基础加速即可)
CONFIG_PACKAGE_luci-app-turboacc=y
CONFIG_PACKAGE_luci-app-turboacc_INCLUDE_OFFLOADING=y

# 界面语言
CONFIG_LUCI_LANG_zh_Hans=y

# 移除冗余应用 (看着精简)
# CONFIG_PACKAGE_luci-app-access-control is not set
# CONFIG_PACKAGE_luci-app-arpbind is not set
# CONFIG_PACKAGE_luci-app-vlmcsd is not set
# CONFIG_PACKAGE_luci-app-vsftpd is not set
# CONFIG_PACKAGE_luci-app-wol is not set
# CONFIG_PACKAGE_luci-app-ddns is not set
